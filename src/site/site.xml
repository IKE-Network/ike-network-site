<site xmlns="http://maven.apache.org/SITE/2.0.0"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="http://maven.apache.org/SITE/2.0.0
      https://maven.apache.org/xsd/site-2.0.0.xsd"
      name="IKE Network">

    <skin>
        <groupId>org.sentrysoftware.maven</groupId>
        <artifactId>sentry-maven-skin</artifactId>
        <version>7.0.00</version>
    </skin>

    <custom>
        <bodyClass>sentry-green</bodyClass>
        <checkImageLinks>false</checkImageLinks>
        <convertImagesToWebp>false</convertImagesToWebp>
        <convertImagesToThumbnails>false</convertImagesToThumbnails>
        <setExplicitImageSize>false</setExplicitImageSize>
        <keywords>IKE, integrated knowledge exchange, sociotechnical fabric,
                   knowledge infrastructure, IKE Network, Maven Central,
                   ike-base-parent, ike-tooling, ike-docs, ike-platform,
                   ike-workspace-extension, doc-example, project-example,
                   integration-tests-example, workspace-example</keywords>
    </custom>

    <bannerLeft name="IKE Network" href="index.html">
        <image src="images/ike-logo.svg" alt="IKE"/>
    </bannerLeft>

    <bannerRight name="GitHub &lt;i class='fa-brands fa-github'&gt;&lt;/i&gt;"
        href="https://github.com/IKE-Network"/>

    <publishDate format="yyyy-MM-dd"/>

    <body>
        <breadcrumbs>
            <item name="IKE" href="index.html"/>
        </breadcrumbs>

        <links>
            <item name="GitHub" href="https://github.com/IKE-Network"/>
            <item name="Issues" href="https://github.com/IKE-Network/ike-issues"/>
        </links>

        <menu name="IKE Network">
            <item name="Home" href="index.html"/>
        </menu>

        <menu name="Foundation">
            <item name="IKE Base Parent"
                  href="https://ike.network/ike-base-parent/"/>
            <item name="IKE Tooling"
                  href="https://ike.network/ike-tooling/"/>
            <item name="IKE Docs"
                  href="https://ike.network/ike-docs/"/>
            <item name="IKE Workspace Extension"
                  href="https://ike.network/ike-workspace-extension/"/>
            <item name="IKE Platform"
                  href="https://ike.network/ike-platform/"/>
        </menu>

        <menu name="Examples">
            <item name="doc-example"
                  href="https://ike.network/doc-example/"/>
            <item name="project-example"
                  href="https://ike.network/project-example/"/>
            <item name="integration-tests-example"
                  href="https://ike.network/integration-tests-example/"/>
            <item name="workspace-example"
                  href="https://ike.network/workspace-example/"/>
        </menu>

        <menu name="Source">
            <item name="ike-base-parent"
                  href="https://github.com/IKE-Network/ike-base-parent"/>
            <item name="ike-tooling"
                  href="https://github.com/IKE-Network/ike-tooling"/>
            <item name="ike-docs"
                  href="https://github.com/IKE-Network/ike-docs"/>
            <item name="ike-workspace-extension"
                  href="https://github.com/IKE-Network/ike-workspace-extension"/>
            <item name="ike-platform"
                  href="https://github.com/IKE-Network/ike-platform"/>
            <item name="doc-example"
                  href="https://github.com/IKE-Network/doc-example"/>
            <item name="project-example"
                  href="https://github.com/IKE-Network/project-example"/>
            <item name="integration-tests-example"
                  href="https://github.com/IKE-Network/integration-tests-example"/>
            <item name="workspace-example"
                  href="https://github.com/IKE-Network/workspace-example"/>
        </menu>
    </body>
</site>
